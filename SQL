-- RLS 有効化
alter table categories enable row level security;
alter table places     enable row level security;
alter table items      enable row level security;

-- ポリシー作成
create policy "allow_all" on categories for all using (true) with check (true);
create policy "allow_all" on places     for all using (true) with check (true);
create policy "allow_all" on items      for all using (true) with check (true);

-- Storage ポリシー
create policy "allow_all_storage"
  on storage.objects for all
  using (bucket_id = 'item-images')
  with check (bucket_id = 'item-images');
