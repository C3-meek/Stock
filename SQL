-- テーブル作成
create table categories (
  id         bigserial primary key,
  name       text not null unique,
  created_at timestamptz default now()
);

create table places (
  id         bigserial primary key,
  name       text not null unique,
  created_at timestamptz default now()
);

create table items (
  id            bigserial primary key,
  name          text not null,
  category      text,
  qty           integer default 1,
  place         text,
  supplier      text,
  purchase_date date,
  expiry        date,
  memo          text,
  image_url     text,
  status        text default 'active',
  warn_days     integer,
  created_at    timestamptz default now()
);

